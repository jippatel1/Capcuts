<reference id="reference-6773" class="- topic/topic       reference/reference ">
  <title class="- topic/title ">CapCut Terms, Icons, and Recommended Export Settings</title>
  <shortdesc class="- topic/shortdesc ">Use this quick reference guide to understand common CapCut terms, editing icons, and recommended export settings for social media videos. This topic is intended to help beginner users quickly find information while editing.</shortdesc>
  <prolog class="- topic/prolog ">
    <author translate="no" type="creator" class="- topic/author ">Jivesh Patel &lt;jippatel@ucdavis.edu&gt;</author>
    <metadata class="- topic/metadata ">
      <keywords class="- topic/keywords "/>
    </metadata>
  </prolog>
  <refbody class="- topic/body        reference/refbody ">
    <section class="- topic/section ">
      <title class="- topic/title ">Common Capcut Editing Terms</title>
      <p class="- topic/p ">The following terms are commonly used while editing videos in CapCut. Understanding these terms can make the editing process easier and help users follow instructions more confidently.</p>
      <p class="- topic/p ">
        <table class="- topic/table ">
          <tgroup cols="1" class="- topic/tgroup ">
            <colspec colname="c1" colnum="1" colwidth="1*" class="- topic/colspec "/>
            <tbody class="- topic/tbody ">
              <row class="- topic/row ">
                <entry class="- topic/entry ">Table 1: Editing Terms</entry>
              </row>
            </tbody>
          </tgroup>
        </table>
        <table class="- topic/table ">
          <tgroup cols="3" class="- topic/tgroup ">
            <colspec colname="col1" class="- topic/colspec "/>
            <colspec colname="col2" class="- topic/colspec "/>
            <colspec colname="col3" class="- topic/colspec "/>
            <thead class="- topic/thead ">
              <row class="- topic/row ">
                <entry class="- topic/entry ">
                  <b class="+ topic/ph hi-d/b ">Term</b>
                </entry>
                <entry class="- topic/entry ">
                  <b class="+ topic/ph hi-d/b ">Definition</b>
                </entry>
                <entry class="- topic/entry ">
                  <b class="+ topic/ph hi-d/b ">Why It Matters</b>
                </entry>
              </row>
            </thead>
            <tbody class="- topic/tbody ">
              <row class="- topic/row ">
                <entry class="- topic/entry ">Timeline</entry>
                <entry class="- topic/entry ">The main editing area where clips are organized</entry>
                <entry class="- topic/entry ">Used for arranging and editing videos</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Trim</entry>
                <entry class="- topic/entry ">Shortening a clip by removing unwanted footage</entry>
                <entry class="- topic/entry ">Helps remove unnecessary sections</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Split</entry>
                <entry class="- topic/entry ">Dividing a clip into separate parts</entry>
                <entry class="- topic/entry ">Makes editing specific sections easier</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Transition</entry>
                <entry class="- topic/entry ">Effect between clips</entry>
                <entry class="- topic/entry ">Helps videos flow more smoothly</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Text Overlay</entry>
                <entry class="- topic/entry ">Words displayed on a video</entry>
                <entry class="- topic/entry ">Used for captions or titles</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Audio Track</entry>
                <entry class="- topic/entry ">Music or sounds added to a video</entry>
                <entry class="- topic/entry ">Improves engagement and pacing</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Effect</entry>
                <entry class="- topic/entry ">Visual enhancement added to clips</entry>
                <entry class="- topic/entry ">Improves video appearance</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Export</entry>
                <entry class="- topic/entry ">Saving the finished video</entry>
                <entry class="- topic/entry ">Required before posting online</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Frame Rate</entry>
                <entry class="- topic/entry ">Number of frames displayed per second</entry>
                <entry class="- topic/entry ">Affects video smoothness</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">Resolution</entry>
                <entry class="- topic/entry ">Video quality level</entry>
                <entry class="- topic/entry ">Impacts video clarity</entry>
              </row>
            </tbody>
          </tgroup>
        </table>
      </p>
    </section>
    <section class="- topic/section ">
      <title class="- topic/title ">Common CapCut Icons</title>
      <p class="- topic/p ">CapCut uses icons to represent editing tools. The following icons are commonly used when creating and editing videos.</p>
      <p class="- topic/p ">
        <table class="- topic/table ">
          <tgroup cols="1" class="- topic/tgroup ">
            <colspec colname="c1" colnum="1" colwidth="1*" class="- topic/colspec "/>
