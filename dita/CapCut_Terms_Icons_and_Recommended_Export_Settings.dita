                  <b class="+ topic/ph hi-d/b ">Tool Name</b>
                </entry>
                <entry class="- topic/entry ">
                  <b class="+ topic/ph hi-d/b ">Purpose</b>
                </entry>
              </row>
            </thead>
            <tbody class="- topic/tbody ">
              <row class="- topic/row ">
                <entry class="- topic/entry ">+</entry>
                <entry class="- topic/entry ">Add Clip</entry>
                <entry class="- topic/entry ">Imports videos or photos</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">T</entry>
                <entry class="- topic/entry ">Text</entry>
                <entry class="- topic/entry ">Adds captions or titles</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">🎵</entry>
                <entry class="- topic/entry ">Audio</entry>
                <entry class="- topic/entry ">Adds music and sounds</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">✂</entry>
                <entry class="- topic/entry ">Split</entry>
                <entry class="- topic/entry ">Cuts clips into sections</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">⇄</entry>
                <entry class="- topic/entry ">Transition</entry>
                <entry class="- topic/entry ">Adds effects between clips</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">⭐</entry>
                <entry class="- topic/entry ">Effects</entry>
                <entry class="- topic/entry ">Applies visual enhancements</entry>
              </row>
              <row class="- topic/row ">
                <entry class="- topic/entry ">↑</entry>
                <entry class="- topic/entry ">Export</entry>
                <entry class="- topic/entry ">Saves completed video</entry>
              </row>
            </tbody>
          </tgroup>
        </table>
      </p>
    </section>
    <section class="- topic/section ">
